#!/usr/bin/env bash

set -euo pipefail

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
THEME_ROOT="$CONFIG_HOME/themes"
PROFILE_DIR="$THEME_ROOT/profiles"
GENERATED_DIR="$THEME_ROOT/generated"
CURRENT_FILE="$THEME_ROOT/current"
OPENCODE_TUI="$CONFIG_HOME/opencode/tui.json"
REQUIRED_PROFILE_FILES=(
  manifest.sh
  nvim.lua
  nvim-new.lua
  tmux.conf
  wezterm.lua
  alacritty.toml
)

usage() {
  cat <<'EOF'
Usage:
  theme-switch list
  theme-switch current
  theme-switch validate <theme>
  theme-switch apply [--dry-run] <theme>

Examples:
  theme-switch validate kanagawa-dragon
  theme-switch apply kanagawa-dragon
  theme-switch apply --dry-run catppuccin
EOF
}

list_themes() {
  local path

  for path in "$PROFILE_DIR"/*; do
    [[ -d "$path" ]] || continue
    [[ -f "$path/manifest.sh" ]] || continue
    basename "$path"
  done | sort
}

theme_path() {
  printf '%s\n' "$PROFILE_DIR/$1"
}

validate_profile() {
  local theme_id="$1"
  local profile_path
  local file_name

  profile_path="$(theme_path "$theme_id")"

  if [[ ! -d "$profile_path" ]]; then
    printf 'Unknown theme: %s\n' "$theme_id" >&2
    exit 1
  fi

  for file_name in "${REQUIRED_PROFILE_FILES[@]}"; do
    if [[ ! -f "$profile_path/$file_name" ]]; then
      printf 'Theme %s is missing %s\n' "$theme_id" "$file_name" >&2
      exit 1
    fi
  done

  printf 'Theme %s looks valid\n' "$theme_id"
}

load_manifest() {
  local theme_id="$1"
  local profile_path

  profile_path="$(theme_path "$theme_id")"

  if [[ ! -f "$profile_path/manifest.sh" ]]; then
    printf 'Unknown theme: %s\n' "$theme_id" >&2
    exit 1
  fi

  # shellcheck disable=SC1090
  source "$profile_path/manifest.sh"

  : "${THEME_ID:?Theme manifest must set THEME_ID}"
  : "${THEME_LABEL:?Theme manifest must set THEME_LABEL}"
  : "${OPENCODE_THEME:?Theme manifest must set OPENCODE_THEME}"

  if [[ "$THEME_ID" != "$theme_id" ]]; then
    printf 'Theme manifest mismatch: expected %s but got %s\n' "$theme_id" "$THEME_ID" >&2
    exit 1
  fi
}

update_opencode_tui() {
  python3 - "$OPENCODE_TUI" "$OPENCODE_THEME" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1]).expanduser()
theme = sys.argv[2]

data = json.loads(path.read_text())
data["theme"] = theme
path.write_text(json.dumps(data, indent=2) + "\n")
PY
}

copy_generated_files() {
  local theme_id="$1"
  local profile_path

  profile_path="$(theme_path "$theme_id")"

  mkdir -p "$GENERATED_DIR"
  cp "$profile_path/nvim.lua" "$GENERATED_DIR/nvim.lua"
  cp "$profile_path/nvim-new.lua" "$GENERATED_DIR/nvim-new.lua"
  cp "$profile_path/tmux.conf" "$GENERATED_DIR/tmux.conf"
  cp "$profile_path/wezterm.lua" "$GENERATED_DIR/wezterm.lua"
  cp "$profile_path/alacritty.toml" "$GENERATED_DIR/alacritty.toml"
}

describe_apply() {
  printf 'Would set current theme to %s\n' "$THEME_ID"
  printf 'Would write %s\n' "$CURRENT_FILE"
  printf 'Would write %s\n' "$GENERATED_DIR/nvim.lua"
  printf 'Would write %s\n' "$GENERATED_DIR/nvim-new.lua"
  printf 'Would write %s\n' "$GENERATED_DIR/tmux.conf"
  printf 'Would write %s\n' "$GENERATED_DIR/wezterm.lua"
  printf 'Would write %s\n' "$GENERATED_DIR/alacritty.toml"
  printf 'Would update theme in %s\n' "$OPENCODE_TUI"
}

apply_theme() {
  local dry_run="$1"
  local theme_id="$2"

  validate_profile "$theme_id" >/dev/null
  load_manifest "$theme_id"

  if [[ "$dry_run" == "true" ]]; then
    describe_apply
    return
  fi

  copy_generated_files "$theme_id"
  printf '%s\n' "$THEME_ID" > "$CURRENT_FILE"
  update_opencode_tui
  printf 'Applied theme: %s\n' "$THEME_ID"
}

main() {
  local command="${1:-}"

  case "$command" in
    list)
      list_themes
      ;;
    current)
      if [[ -f "$CURRENT_FILE" ]]; then
        cat "$CURRENT_FILE"
      else
        printf 'No active theme set\n' >&2
        exit 1
      fi
      ;;
    validate)
      shift

      if [[ $# -ne 1 ]]; then
        usage >&2
        exit 1
      fi

      validate_profile "$1"
      ;;
    apply)
      shift
      local dry_run=false

      if [[ "${1:-}" == "--dry-run" ]]; then
        dry_run=true
        shift
      fi

      if [[ $# -ne 1 ]]; then
        usage >&2
        exit 1
      fi

      apply_theme "$dry_run" "$1"
      ;;
    "")
      usage
      ;;
    *)
      if [[ -d "$PROFILE_DIR/$command" ]]; then
        apply_theme false "$command"
      else
        usage >&2
        exit 1
      fi
      ;;
  esac
}

main "$@"
