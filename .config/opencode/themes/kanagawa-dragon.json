{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "dragonBlack": "#181616",
    "dragonPanel": "#1f1f28",
    "dragonElement": "#282727",
    "dragonBorder": "#393836",
    "dragonBorderActive": "#625e5a",
    "dragonText": "#c5c9c5",
    "dragonMuted": "#a6a69c",
    "dragonBlue": "#7e9cd8",
    "dragonCyan": "#7aa89f",
    "dragonGreen": "#87a987",
    "dragonYellow": "#e6c384",
    "dragonOrange": "#b6927b",
    "dragonRed": "#c4746e",
    "dragonPurple": "#957fb8"
  },
  "theme": {
    "primary": { "dark": "dragonBlue", "light": "dragonBlue" },
    "secondary": { "dark": "dragonPurple", "light": "dragonPurple" },
    "accent": { "dark": "dragonCyan", "light": "dragonCyan" },
    "error": { "dark": "dragonRed", "light": "dragonRed" },
    "warning": { "dark": "dragonOrange", "light": "dragonOrange" },
    "success": { "dark": "dragonGreen", "light": "dragonGreen" },
    "info": { "dark": "dragonBlue", "light": "dragonBlue" },
    "text": { "dark": "dragonText", "light": "dragonText" },
    "textMuted": { "dark": "dragonMuted", "light": "dragonMuted" },
    "background": { "dark": "dragonBlack", "light": "dragonBlack" },
    "backgroundPanel": { "dark": "dragonPanel", "light": "dragonPanel" },
    "backgroundElement": { "dark": "dragonElement", "light": "dragonElement" },
    "border": { "dark": "dragonBorder", "light": "dragonBorder" },
    "borderActive": { "dark": "dragonBorderActive", "light": "dragonBorderActive" },
    "borderSubtle": { "dark": "dragonBorder", "light": "dragonBorder" },
    "diffAdded": { "dark": "dragonGreen", "light": "dragonGreen" },
    "diffRemoved": { "dark": "dragonRed", "light": "dragonRed" },
    "diffContext": { "dark": "dragonMuted", "light": "dragonMuted" },
    "diffHunkHeader": { "dark": "dragonPurple", "light": "dragonPurple" },
    "diffHighlightAdded": { "dark": "dragonGreen", "light": "dragonGreen" },
    "diffHighlightRemoved": { "dark": "dragonRed", "light": "dragonRed" },
    "diffAddedBg": { "dark": "dragonPanel", "light": "dragonPanel" },
    "diffRemovedBg": { "dark": "dragonPanel", "light": "dragonPanel" },
    "diffContextBg": { "dark": "dragonBlack", "light": "dragonBlack" },
    "diffLineNumber": { "dark": "dragonMuted", "light": "dragonMuted" },
    "diffAddedLineNumberBg": { "dark": "dragonPanel", "light": "dragonPanel" },
    "diffRemovedLineNumberBg": { "dark": "dragonPanel", "light": "dragonPanel" },
    "markdownText": { "dark": "dragonText", "light": "dragonText" },
    "markdownHeading": { "dark": "dragonBlue", "light": "dragonBlue" },
    "markdownLink": { "dark": "dragonCyan", "light": "dragonCyan" },
    "markdownLinkText": { "dark": "dragonBlue", "light": "dragonBlue" },
    "markdownCode": { "dark": "dragonGreen", "light": "dragonGreen" },
    "markdownBlockQuote": { "dark": "dragonMuted", "light": "dragonMuted" },
    "markdownEmph": { "dark": "dragonOrange", "light": "dragonOrange" },
    "markdownStrong": { "dark": "dragonYellow", "light": "dragonYellow" },
    "markdownHorizontalRule": { "dark": "dragonBorder", "light": "dragonBorder" },
    "markdownListItem": { "dark": "dragonPurple", "light": "dragonPurple" },
    "markdownListEnumeration": { "dark": "dragonOrange", "light": "dragonOrange" },
    "markdownImage": { "dark": "dragonCyan", "light": "dragonCyan" },
    "markdownImageText": { "dark": "dragonBlue", "light": "dragonBlue" },
    "markdownCodeBlock": { "dark": "dragonText", "light": "dragonText" },
    "syntaxComment": { "dark": "dragonMuted", "light": "dragonMuted" },
    "syntaxKeyword": { "dark": "dragonPurple", "light": "dragonPurple" },
    "syntaxFunction": { "dark": "dragonBlue", "light": "dragonBlue" },
    "syntaxVariable": { "dark": "dragonText", "light": "dragonText" },
    "syntaxString": { "dark": "dragonGreen", "light": "dragonGreen" },
    "syntaxNumber": { "dark": "dragonOrange", "light": "dragonOrange" },
    "syntaxType": { "dark": "dragonYellow", "light": "dragonYellow" },
    "syntaxOperator": { "dark": "dragonRed", "light": "dragonRed" },
    "syntaxPunctuation": { "dark": "dragonText", "light": "dragonText" }
  }
}
